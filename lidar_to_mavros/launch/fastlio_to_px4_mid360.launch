<launch>
    <!--
        px4sim MID360 唯一主启动文件。

        默认流程：
        1. 启动 FAST-LIO，读取 /livox/lidar 和 /livox/imu。
        2. lidar_to_mavros 启动后先采样 /livox/imu，自动计算 roll/pitch 坐标旋转补偿。
        3. 校准锁定后，把 /Odom_high_freq 转成 /mavros/vision_pose/pose 发给 PX4。
        4. 默认同时启动 fastlio_cloud_align，把 /cloud_registered 转成 /cloud_registered_aligned 给 EGO 建图。

        默认安装外参：
        - 平移 mount_x/y/z 为 0，因为当前仿真里雷达和飞控很近。
        - 旋转 mount_pitch 为 30 度，因为 MID360 是前倾安装。
        注意：mount_pitch 是“雷达坐标 -> 机体坐标”的安装外参；
        imu_auto 是“FAST-LIO 坐标变化 -> PX4 世界坐标”的自动旋转补偿，两者不是同一个东西。
        yaw 不自动补偿。

        固定 30 度回退测试：
        roslaunch lidar_to_mavros fastlio_to_px4_mid360.launch align_mode:=fixed world_pitch:=0.523598775598
    -->
    <!-- 是否同时打开 FAST-LIO 的 RViz。 -->
    <arg name="rviz" default="false"/>
    <!-- FAST-LIO MID360 近距离盲区，滤掉无人机本体/桨叶等自机点。单位：m。 -->
    <arg name="fastlio_blind" default="0.35"/>

    <!-- 坐标旋转模式：imu_auto=默认从 /livox/imu 自动算 roll/pitch；fixed=使用 world_roll/pitch/yaw；none=不旋转。 -->
    <arg name="align_mode" default="imu_auto"/>

    <!-- FAST-LIO 输出位姿、IMU 自动校准输入、发给 MAVROS/PX4 的输出 topic。 -->
    <arg name="odom_topic" default="/Odom_high_freq"/>
    <arg name="imu_topic" default="/livox/imu"/>
    <arg name="vision_pose_topic" default="/mavros/vision_pose/pose"/>

    <!-- FAST-LIO 世界点云输入、对齐后给 EGO-Planner 使用的点云输出。 -->
    <arg name="enable_cloud_align" default="true"/>
    <arg name="cloud_topic" default="/cloud_registered"/>
    <arg name="aligned_cloud_topic" default="/cloud_registered_aligned"/>
    <arg name="cloud_output_frame_id" default="world"/>

    <!-- 传感器安装外参。平移先忽略；pitch=0.523598775598 rad 表示 MID360 前倾 30 度安装。 -->
    <arg name="mount_x" default="0.0"/>
    <arg name="mount_y" default="0.0"/>
    <arg name="mount_z" default="0.0"/>
    <arg name="mount_roll" default="0.0"/>
    <arg name="mount_pitch" default="0.523598775598"/>
    <arg name="mount_yaw" default="0.0"/>

    <!-- 固定角补偿参数。只有 align_mode:=fixed 时使用；默认 imu_auto 下保持 0。 -->
    <arg name="world_x" default="0.0"/>
    <arg name="world_y" default="0.0"/>
    <arg name="world_z" default="0.0"/>
    <arg name="world_roll" default="0.0"/>
    <arg name="world_pitch" default="0.0"/>
    <arg name="world_yaw" default="0.0"/>

    <!-- zero_origin=true 表示输出坐标从启动后第一帧归零，适合发给 PX4 做局部定位。 -->
    <arg name="zero_origin" default="true"/>

    <!-- print_debug=true 默认打印输出位姿、PX4 local pose 坐标表。 -->
    <arg name="print_debug" default="true"/>
    <!-- cloud_print_debug=false 默认关闭点云节点周期状态打印，避免和上面的坐标表抢终端输出。 -->
    <arg name="cloud_print_debug" default="false"/>

    <!-- IMU 自动校准参数：启动静止采样时间、最少样本数、允许的 roll/pitch 抖动阈值。 -->
    <arg name="startup_align_duration" default="2.0"/>
    <arg name="min_align_samples" default="50"/>
    <arg name="max_align_rpy_stddev_deg" default="3.0"/>

    <!-- 启动 FAST-LIO MID360 建图。 -->
    <include file="$(find fast_lio)/launch/mapping_mid360.launch">
        <arg name="rviz" value="$(arg rviz)"/>
        <arg name="blind" value="$(arg fastlio_blind)"/>
    </include>

    <!-- 启动 FAST-LIO 到 PX4 的坐标转换节点。 -->
    <node name="lidar_to_mavros" pkg="lidar_to_mavros" type="lidar_to_mavros" output="screen">
        <param name="odom_topic" value="$(arg odom_topic)"/>
        <param name="imu_topic" value="$(arg imu_topic)"/>
        <param name="vision_pose_topic" value="$(arg vision_pose_topic)"/>
        <param name="output_frame_id" value="odom"/>

        <param name="mount_x" value="$(arg mount_x)"/>
        <param name="mount_y" value="$(arg mount_y)"/>
        <param name="mount_z" value="$(arg mount_z)"/>
        <param name="mount_roll" value="$(arg mount_roll)"/>
        <param name="mount_pitch" value="$(arg mount_pitch)"/>
        <param name="mount_yaw" value="$(arg mount_yaw)"/>

        <param name="world_x" value="$(arg world_x)"/>
        <param name="world_y" value="$(arg world_y)"/>
        <param name="world_z" value="$(arg world_z)"/>
        <param name="world_roll" value="$(arg world_roll)"/>
        <param name="world_pitch" value="$(arg world_pitch)"/>
        <param name="world_yaw" value="$(arg world_yaw)"/>

        <param name="align_mode" value="$(arg align_mode)"/>
        <param name="startup_align_duration" value="$(arg startup_align_duration)"/>
        <param name="min_align_samples" value="$(arg min_align_samples)"/>
        <param name="max_align_rpy_stddev_deg" value="$(arg max_align_rpy_stddev_deg)"/>
        <param name="zero_origin" value="$(arg zero_origin)"/>
        <param name="print_debug" value="$(arg print_debug)"/>
    </node>

    <!-- 启动独立点云转换节点。它只发布 /cloud_registered_aligned，不发 PX4 位姿。 -->
    <group if="$(arg enable_cloud_align)">
        <include file="$(find lidar_to_mavros)/launch/cloud_align_mid360.launch">
            <arg name="cloud_topic" value="$(arg cloud_topic)"/>
            <arg name="aligned_cloud_topic" value="$(arg aligned_cloud_topic)"/>
            <arg name="imu_topic" value="$(arg imu_topic)"/>
            <arg name="odom_topic" value="$(arg odom_topic)"/>
            <arg name="output_frame_id" value="$(arg cloud_output_frame_id)"/>
            <arg name="align_mode" value="$(arg align_mode)"/>
            <arg name="world_x" value="$(arg world_x)"/>
            <arg name="world_y" value="$(arg world_y)"/>
            <arg name="world_z" value="$(arg world_z)"/>
            <arg name="world_roll" value="$(arg world_roll)"/>
            <arg name="world_pitch" value="$(arg world_pitch)"/>
            <arg name="world_yaw" value="$(arg world_yaw)"/>
            <arg name="zero_origin" value="$(arg zero_origin)"/>
            <arg name="print_debug" value="$(arg cloud_print_debug)"/>
            <arg name="startup_align_duration" value="$(arg startup_align_duration)"/>
            <arg name="min_align_samples" value="$(arg min_align_samples)"/>
            <arg name="max_align_rpy_stddev_deg" value="$(arg max_align_rpy_stddev_deg)"/>
        </include>
    </group>
</launch>
