<launch>
    <!--
        D435 standalone RGB + depth + pointcloud launch.

        Default outputs:
        - /camera/color/image_raw
        - /camera/depth/image_rect_raw
        - /camera/depth/color/points

        IMU streams are disabled.
    -->

    <arg name="camera" default="camera"/>
    <arg name="initial_reset" default="true"/>

    <arg name="color_width" default="640"/>
    <arg name="color_height" default="480"/>
    <arg name="color_fps" default="30"/>

    <arg name="depth_width" default="640"/>
    <arg name="depth_height" default="480"/>
    <arg name="depth_fps" default="30"/>

    <arg name="align_depth" default="false"/>
    <arg name="enable_sync" default="false"/>
    <arg name="enable_pointcloud" default="true"/>
    <arg name="ordered_pc" default="false"/>
    <arg name="clip_distance" default="5.0"/>

    <env name="LD_LIBRARY_PATH"
         value="/opt/ros/noetic/lib/aarch64-linux-gnu:$(env LD_LIBRARY_PATH)"/>

    <include file="$(find realsense2_camera)/launch/rs_camera.launch">
        <arg name="camera" value="$(arg camera)"/>
        <arg name="initial_reset" value="$(arg initial_reset)"/>

        <arg name="enable_color" value="true"/>
        <arg name="color_width" value="$(arg color_width)"/>
        <arg name="color_height" value="$(arg color_height)"/>
        <arg name="color_fps" value="$(arg color_fps)"/>

        <arg name="enable_depth" value="true"/>
        <arg name="depth_width" value="$(arg depth_width)"/>
        <arg name="depth_height" value="$(arg depth_height)"/>
        <arg name="depth_fps" value="$(arg depth_fps)"/>

        <arg name="enable_infra" value="false"/>
        <arg name="enable_infra1" value="false"/>
        <arg name="enable_infra2" value="false"/>
        <arg name="enable_gyro" value="false"/>
        <arg name="enable_accel" value="false"/>

        <arg name="align_depth" value="$(arg align_depth)"/>
        <arg name="enable_sync" value="$(arg enable_sync)"/>
        <arg name="enable_pointcloud" value="$(arg enable_pointcloud)"/>
        <arg name="pointcloud_texture_stream" value="RS2_STREAM_COLOR"/>
        <arg name="ordered_pc" value="$(arg ordered_pc)"/>
        <arg name="clip_distance" value="$(arg clip_distance)"/>
    </include>
</launch>
